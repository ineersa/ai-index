{
    "name": "ineersa/ai-index",
    "description": "AI index for Symfony projects with map, callgraph and wiring information.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Ineersa\\AiIndex\\": "src/"
        }
    },
    "bin": [
        "bin/ai-index"
    ],
    "authors": [
        {
            "name": "Illia Vasylevskyi",
            "email": "ineersa@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.5",
        "symfony/console": "^8.0",
        "helgesverre/toon": "^1.0 || ^3.1",
        "nikic/php-parser": "^5.7",
        "symfony/dependency-injection": "^8.0",
        "symfony/http-kernel": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.1"
    }
}
